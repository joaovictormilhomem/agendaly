# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Database
DB_CONNECTION=pg
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=apjf834ab
DB_DATABASE=agendaly

#--------------------------------------------------------------------
# Testes (`npm test`)
#--------------------------------------------------------------------
# Use um banco separado para não misturar dados com o dev:
#   CREATE DATABASE agendaly;
# Copie as variáveis acima para `.env.test` ou ajuste DB_USER/DB_PASSWORD/DB_DATABASE.
# O mesmo usuário precisa de permissão no schema public do banco de teste.

# Auth (JWT)
JWT_ACCESS_SECRET=test-access
JWT_REFRESH_SECRET=test-refresh

# Session
SESSION_DRIVER=cookie

#--------------------------------------------------------------------
# CORS (configure allowed origins for API access)
#--------------------------------------------------------------------
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000

#--------------------------------------------------------------------
# WhatsApp (serviço separado whatsapp-worker + whatsapp-web.js)
#--------------------------------------------------------------------
# WHATSAPP_BRIDGE_URL=http://127.0.0.1:3334
# WHATSAPP_BRIDGE_SECRET=defina-o-mesmo-no-worker